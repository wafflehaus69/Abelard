# Copy to .env (git-ignored) and fill in real values. The daemon loads this
# .env at startup (resolved next to pyproject.toml, regardless of cwd). Shell
# environment variables override .env values; .env only fills the gaps.

# Required — Finnhub key for the US symbol universe. Read from env only;
# never logged.
FINNHUB_API_KEY=your_finnhub_free_tier_key_here

# Required at sentiment time (when attention-tier tickers exist), not at
# startup. A missing key surfaces as a structured error on the Haiku pass.
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional overrides (defaults shown).
# BIZ_DAEMON_DB_PATH=~/.openclaw/biz_daemon/biz_daemon.sqlite3
# BIZ_DAEMON_ATTENTION_N=5
# BIZ_DAEMON_READ_BULL_PCT=55
# BIZ_DAEMON_READ_BEAR_PCT=55
LOG_LEVEL=INFO
