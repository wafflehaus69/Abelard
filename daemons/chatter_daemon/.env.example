# ChatterDaemon environment contract.
# config.py auto-loads this .env at startup (override=False — a value already set
# in the shell wins; a missing .env no-ops, it never crashes the spine).
#
# Order 1 (the spine) needs NO credentials — it loads watchlists and derives
# windows entirely offline. Source credentials arrive with their plugins and
# become required only at that plugin's invocation, never at spine startup.
#
# Copy this file to `.env` and fill in your keys. `.env` is gitignored — never
# commit real secrets (this tree lives on /mnt/c, one `git add` from a leak).

# FINNHUB_API_KEY=...     # Finnhub company-news + US symbol universe (Order 2/4)
# ANTHROPIC_API_KEY=...   # Haiku stance over StockTwits message bodies (Order 6/9).
#                         #   OPTIONAL: without it StockTwits still ships the zero-cost
#                         #   native Bull/Bear tag read; Haiku just doesn't run.
#
# Sources that need NO key:
#   StockTwits    — trending + symbol streams are public (browser UA).   (Order 9)
#   4chan /smg/   — public JSON API.                                     (Order 3)

# --- optional overrides (defaults in config.py) ---
# CHATTER_WATCHLISTS_DIR=...   # defaults to the watchlists/ dir beside pyproject.toml
# LOG_LEVEL=INFO
# CHATTER_SENTIMENT_MIN=3      # min StockTwits messages before Haiku runs (else native-only)

# --- Twitter/X source (Order 17/21) — ONLY on a host that has the `twitter` CLI (v0.8.x) ---
# Session cookies are read AMBIENT by the CLI; the daemon never logs them. They EXPIRE —
# refresh from a logged-in browser session when Twitter searches start failing.
# TWITTER_AUTH_TOKEN=...
# TWITTER_CT0=...
# CHATTER_TWITTER_ENABLED=1                                     # OFF by default; ON to run Twitter
# CHATTER_TWITTER_BINARY=/home/wafflehouse/.local/bin/twitter   # absolute path -> $PATH irrelevant
# Order 21 — X meters search ~25 requests/rolling-window per account. PRIORITY names are searched
# FIRST (always land); MAX_TICKERS caps to the top-N that fit the quota (the rest get no Twitter
# that scan, logged). MAX_TICKERS=0 attempts all (will time out past ~25). Order the portfolio by
# conviction and the cap keeps your top-N.
# CHATTER_TWITTER_PRIORITY=NVDA,MU
# CHATTER_TWITTER_MAX_TICKERS=25
# CHATTER_TWITTER_PACE=5.0     # seconds between per-ticker searches (burst guard)
# CHATTER_TWITTER_MIN_LIKES=2  # engagement floor (drops zero-like spam)

# --- CH-SRC-1 news sources ---
# Finnhub relevance gate — Finnhub cross-tags peer/macro stories onto every symbol's feed (only
# ~23% of returned heads name the ticker; 35% of headline slots are cross-ticker dupes). ON by
# default: keep a head only if its title names the ticker. CHATTER_FINNHUB_RELEVANCE_GATE=0 keeps
# every cross-tag (the pre-CH-SRC-1 behaviour, inflates mention_count + the anomaly baseline).
# CHATTER_FINNHUB_RELEVANCE_GATE=1
#
# Yahoo per-ticker RSS — keyless fresh headline supplement, relevance-filtered + Finnhub-deduped.
# ON by default (CHATTER_YAHOO_ENABLED=0 to disable).
# CHATTER_YAHOO_MAX_ITEMS=20        # per-feed item pool
# CHATTER_YAHOO_STALE_AFTER_H=48    # freshest item older than this scan-wide -> stale warning
#
# Alpha Vantage NEWS_SENTIMENT — per-ticker news-sentiment axis. Claim a FREE key at
# alphavantage.co and set it here; ABSENT = the source stays OFF (scans unchanged). One call/scan
# covers the watchlist under AV's 25/day free cap.
# ALPHAVANTAGE_API_KEY=...          # or AV_KEY=...
# CHATTER_AV_RELEVANCE_MIN=0.1      # drop AV ticker mentions below this relevance_score
