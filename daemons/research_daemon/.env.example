# Copy to .env (git-ignored) and fill in real values.
# The daemon reads these directly from the environment; it does not parse .env.
# Use a shell loader (direnv, `set -a; source .env; set +a`) or pass via Docker.

FINNHUB_API_KEY=your_finnhub_free_tier_key_here
EDGAR_USER_AGENT=ResearchDaemon contact@example.com
LOG_LEVEL=INFO
