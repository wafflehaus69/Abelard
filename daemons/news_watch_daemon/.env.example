# News Watch Daemon — environment variables.
#
# Copy to .env (git-ignored) and fill in real values, or export them
# via your shell loader (direnv, `set -a; source .env; set +a`).

# ---- foundation ----

# Absolute path to the SQLite database file. Required.
# Mac mini default: ~/Library/Application Support/news-watch-daemon/state.db
NEWS_WATCH_DB_PATH=/tmp/news-watch.db

# Directory of `*.yaml` theme files. Optional.
# Defaults to the `themes/` folder adjacent to the installed package.
# NEWS_WATCH_THEMES_DIR=/absolute/path/to/themes

# Logging verbosity. Optional. Default INFO.
LOG_LEVEL=INFO

# ---- source plugins (Pass A) ----

# Finnhub API key. Required for the finnhub:general source plugin.
# Get one free at https://finnhub.io/register
# When unset, the plugin's fetch() returns status="error"; orchestration
# continues so other sources still run.
FINNHUB_API_KEY=

# Per-source rate-limit guards (optional; defaults are conservative).
# Reserved for future tuning; not read by Pass A code.
# FINNHUB_MAX_CALLS_PER_MINUTE=50

# ---- HTTP transport (Pass A) ----

# User-Agent string sent with every outbound HTTP request.
# Default: news-watch-daemon/<version> (no URL portion until the repo
# is published; substitute a real URL when that happens).
# NEWS_WATCH_USER_AGENT=news-watch-daemon/0.1

# Default per-request timeout in seconds. Positive float. Default 10.0.
# NEWS_WATCH_HTTP_TIMEOUT_S=10.0

# ---- Telegram source (Pass B) ----

# MTProto API credentials. Get api_id + api_hash at https://my.telegram.org.
# All three values are required for Telegram sources to be built; if any
# is missing, the daemon logs a WARN and runs Finnhub + RSS only.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Session string generated by `python -m news_watch_daemon.telegram_setup`
# (one-time interactive flow). NEVER commit; treated as a secret and
# redacted from log output.
TELEGRAM_SESSION_STRING=

# ---- Synthesis layer (Pass C Step 9) ----

# Anthropic API key. Required for the synthesis call (Sonnet) and the
# drift watcher (Haiku). Optional at load time; the synthesize module
# errors cleanly at use time if missing. Redacted from log output.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Absolute path to Abelard's THESES.md (or whichever file holds the
# active thesis list). Optional — when unset, synthesis runs the
# no-theses prompt variant and records a WARN in
# synthesis_metadata.theses_doc_warning. Mac mini deploy points this
# at the OpenClaw workspace copy.
# NEWS_WATCH_THESES_PATH=/absolute/path/to/THESES.md

# ---- Synthesis paths (Pass C Step 4) ----

# Brief archive root. Filesystem source-of-truth Abelard reads via the
# `briefs list|show` CLI. Optional; default `~/.openclaw/news_watch/briefs`.
# NEWS_WATCH_BRIEF_ARCHIVE=

# Synthesis-layer behavior config (thresholds, model IDs, alert sink
# settings). Optional; default is the bundled config/synthesis_config.yaml.
# NEWS_WATCH_SYNTHESIS_CONFIG=

# Append-only JSONL trigger log. Optional;
# default `~/.openclaw/news_watch/trigger_log.jsonl`.
# NEWS_WATCH_TRIGGER_LOG=

# ---- Proposals (Pass C Step 11) ----

# Drift-proposals directory. Holds pending.json (active proposals) +
# resolved.jsonl (append-only audit trail).
# Optional; default `~/.openclaw/news_watch/proposals/`.
# NEWS_WATCH_PROPOSALS_PATH=
