# Copy to .env (git-ignored). Loaded via python-dotenv on CLI start.
# Algorithm/behavior parameters live in config.yaml, NOT here — this file is
# only for secrets and machine-local overrides.

# Optional until M5. Unified Etherscan API key (free tier: 3 calls/sec,
# 100k/day, Polygon chainid=137 included) — register at https://etherscan.io/register
# then API Dashboard -> Add. Used ONLY by the M5 funding-graph fetcher
# (ERC-20 transfer history via api.etherscan.io/v2). NOTE: standalone
# Polygonscan keys/endpoints were sunset 2025-08-15 and no longer work.
# When unset, live chain-data fetchers fail loudly rather than returning
# fabricated data (Rule 1); cached replay works without it.
ETHERSCAN_API_KEY=

# Optional. Overrides config.yaml logging.level. One of DEBUG/INFO/WARNING/ERROR.
LOG_LEVEL=
